# Скопируйте этот файл как .env и заполните значения
# cp .env.example .env

# Telegram бот (получить у @BotFather)
TELEGRAM_BOT_TOKEN=ваш_токен_бота

# Ваш Telegram Chat ID (получить у @userinfobot)
TELEGRAM_CHAT_ID=ваш_chat_id

# URL Google Apps Script (получить после развертывания скрипта)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/ваш_id/exec
